{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "useUnknownInCatchVariables": false,
    "sourceMap": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "noEmit": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noImplicitReturns": true,
    "types": ["chrome", "node"],
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@javdb/sync-protocol": ["packages/sync-protocol/src/index.ts"],
      "@javdb/sync-client": ["packages/sync-client/src/index.ts"]
    }
  },
  "include": [
    "apps/extension/src",
    "packages/sync-protocol/src",
    "packages/sync-client/src",
    "scripts",
    ".storybook"
  ],
  "exclude": [
    "apps/extension/src/**/*.test.ts",
    "apps/extension/src/**/*.test.tsx",
    "apps/extension/src/**/__tests__/**",
    "scripts/**/*.test.ts",
    "tests/**",
    "apps/extension/src/dashboard/dataSync/legacy/**"
  ]
}
