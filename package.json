{
  "name": "javdb-extension",
  "type": "module",
  "version": "1.9.0",
  "description": "Jav 助手",
  "scripts": {
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:build:vercel": "vitepress build docs && node --input-type=module -e \"import fs from 'fs-extra'; await fs.remove('dist'); await fs.copy('docs/.vitepress/dist','dist')\"",
    "docs:preview": "vitepress preview docs",
    "build": "rimraf dist-zip && node --import tsx scripts/build.ts",
    "version": "npm version"
  },
  "dependencies": {
    "fs-extra": "^10.1.0",
    "jszip": "^3.10.1",
    "idb": "^7.1.1"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.23",
    "@types/archiver": "^6.0.3",
    "@types/chrome": "^0.1.1",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^24.1.0",
    "archiver": "^7.0.1",
    "rimraf": "^6.0.1",
    "tsx": "^4.16.2",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vitepress": "^1.6.4"
  },
  "pnpm": {
    "neverBuiltDependencies": [
      "esbuild"
    ],
    "ignoredBuiltDependencies": [
      "esbuild"
    ]
  },
  "packageManager": "pnpm@10.17.0"
}
