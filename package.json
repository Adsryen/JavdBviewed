{
  "name": "javdb-extension",
  "type": "module",
  "version": "1.21.5",
  "license": "AGPL-3.0-only",
  "description": "Jav 助手",
  "scripts": {
    "vitepress:dev": "vitepress dev vitepress --host 127.0.0.1 --port 5174",
    "vitepress:build": "vitepress build vitepress",
    "vitepress:preview": "vitepress preview vitepress",
    "docs:dev": "pnpm run vitepress:dev",
    "docs:build": "pnpm run vitepress:build",
    "docs:preview": "pnpm run vitepress:preview",
    "build": "rimraf dist-zip && node --import tsx scripts/build.ts",
    "typecheck": "tsc --noEmit",
    "test": "pnpm run test:unit && pnpm run test:regression && pnpm run test:extension",
    "test:unit": "vitest run --config vitest.unit.config.cjs",
    "test:regression": "vitest run --config vitest.regression.config.cjs",
    "test:dom": "vitest run --config vitest.dom.config.cjs",
    "test:extension": "vitest run --config vitest.extension.config.cjs",
    "test:style-contract": "vitest run --config vitest.unit.config.cjs src/ui/tokens/themeTokens.test.ts scripts/assert-css-isolation.test.ts src/ui/primitives/Button/Button.test.tsx src/ui/primitives/Input/Input.test.tsx src/ui/primitives/Toggle/Toggle.test.tsx src/ui/primitives/Modal/Modal.test.tsx src/ui/primitives/MediaCover/MediaCover.test.tsx src/ui/primitives/Card/Card.test.tsx src/ui/primitives/Tabs/Tabs.test.tsx src/ui/primitives/Toast/Toast.test.tsx src/ui/patterns/PageHeader/PageHeader.test.tsx src/ui/patterns/EmptyState/EmptyState.test.tsx src/ui/patterns/FilterChip/FilterChip.test.tsx src/ui/patterns/SettingSection/SettingSection.test.tsx src/ui/patterns/SettingToggleRow/SettingToggleRow.test.tsx && node scripts/assert-css-isolation.cjs",
    "test:visual": "playwright test",
    "test:visual:layout": "playwright test tests/visual/mediaGridLayout.visual.spec.ts",
    "test:visual:update": "playwright test --update-snapshots",
    "test:visual:storybook": "playwright test tests/visual/primitives.visual.spec.ts",
    "test:coverage": "vitest run --config vitest.config.cjs --coverage && vitest run --config vitest.dom.config.cjs --coverage && vitest run --config vitest.extension.config.cjs --coverage",
    "test:watch": "vitest --config vitest.config.cjs",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "lint": "pnpm run typecheck",
    "ci": "pnpm run typecheck && pnpm run test && pnpm run test:dom && pnpm run test:style-contract && pnpm run build && pnpm run docs:build",
    "version:major": "pnpm tsx scripts/version.ts major",
    "version:minor": "pnpm tsx scripts/version.ts minor",
    "version:patch": "pnpm tsx scripts/version.ts patch",
    "version:build": "pnpm tsx scripts/version.ts"
  },
  "dependencies": {
    "fs-extra": "^10.1.0",
    "idb": "^7.1.1",
    "jszip": "^3.10.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.4.0",
    "@playwright/test": "^1.61.1",
    "@storybook/addon-essentials": "^8.6.18",
    "@storybook/addon-themes": "^8.6.18",
    "@storybook/blocks": "^8.6.14",
    "@storybook/react": "^8.6.18",
    "@storybook/react-vite": "^8.6.18",
    "@types/archiver": "^6.0.3",
    "@types/chrome": "^0.1.1",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^24.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^2.1.9",
    "archiver": "^7.0.1",
    "autoprefixer": "^10.5.3",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.19",
    "rimraf": "^6.0.1",
    "storybook": "^8.6.18",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.16.2",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vitepress": "^1.6.4",
    "vitepress-plugin-mermaid": "^2.0.17",
    "vitest": "^2.1.9"
  },
  "pnpm": {
    "neverBuiltDependencies": [
      "esbuild"
    ],
    "ignoredBuiltDependencies": [
      "esbuild"
    ]
  },
  "packageManager": "pnpm@10.17.0"
}
